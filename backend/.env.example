# Salin ke .env lalu sesuaikan.

# Kosongkan untuk memakai SQLite (default). Isi untuk PostgreSQL:
# DATABASE_URL=postgresql://lms:lms@localhost:5432/smkn1pati

# Wajib diganti di produksi:
LMS_SECRET_KEY=ganti-kunci-ini-di-produksi

# Masa berlaku token (jam) — default 168 (7 hari)
LMS_TOKEN_TTL_HOURS=168

# Origin yang diizinkan (pisahkan dengan koma), default "*"
LMS_CORS_ORIGINS=*
